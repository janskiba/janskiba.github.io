---
import Layout from "../layouts/Layout.astro";
import ArrowLink from "../components/ArrowLink.astro";
import aboutMeImage from "../assets/about-me.jpeg";

const skills: Record<string, string[]> = {
  "Frameworks & libraries": [
    "Angular",
    "Angular Material",
    "Bootstrap",
    "ng-bootstrap",
    "Leaflet",
    "Tailwind CSS",
    "React",
  ],
  "Languages & styling": ["TypeScript", "JavaScript", "HTML5", "SCSS"],
  Reactive: ["RxJS", "NgRx", "Angular Signals"],
  Testing: ["Cypress", "Playwright", "Jasmine"],
  "OS & tools": ["Linux", "Docker", "Jenkins", "Bitbucket", "Git", "Jira"],
};
---

<Layout
  title="About me | janskiba.dev"
  description="Frontend developer focused on Angular, TypeScript and modern web engineering."
>
  <section class="py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div
        class="group relative overflow-hidden rounded-2xl p-6 sm:p-8 border border-gray-700/50 backdrop-blur-sm bg-linear-to-br from-gray-800/50 to-gray-900/50 hover:border-blue-500/40 transition-all duration-300 hover:shadow-xl hover:shadow-blue-500/10"
      >
        <!-- Hover gradient overlay -->
        <div
          class="pointer-events-none absolute inset-0 rounded-2xl bg-linear-to-r from-blue-500/0 via-purple-500/0 to-pink-500/0 group-hover:from-blue-500/5 group-hover:via-purple-500/5 group-hover:to-pink-500/5 transition-all duration-300"
        >
        </div>

        <div
          class="relative grid gap-6 sm:grid-cols-[120px_1fr] sm:items-start"
        >
          <!-- Profile photo -->
          <div class="flex sm:block mx-auto">
            <div
              class="h-24 w-24 sm:h-28 sm:w-28 rounded-2xl overflow-hidden border border-gray-700/60 bg-gray-800/40"
            >
              <img
                src={aboutMeImage.src}
                alt="Profile photo"
                class="h-full w-full object-cover"
              />
            </div>
          </div>

          <!-- Content -->
          <div class="space-y-4">
            <div>
              <h2 class="text-2xl font-bold text-gray-100">About me</h2>
              <p class="mt-2 text-gray-300 leading-relaxed">
                I'm a software developer focused on building modern,
                maintainable web applications—mostly in the Angular ecosystem. I
                enjoy turning complex requirements into clean UI, solid
                architecture, and reliable delivery pipelines.
              </p>
            </div>

            <p class="text-gray-300 leading-relaxed">
              My go-to stack includes Angular and Angular Material, along with
              TypeScript and SCSS. I also have extensive experience in working
              with complex maps in leaflet.
            </p>

            <p class="text-gray-300 leading-relaxed">
              Quality matters to me, so I regularly write automated tests with
              Cypress, Playwright, and Jasmine. On the tooling side, I'm
              comfortable with Linux, Docker, Jenkins, Bitbucket, Git, and Jira.
            </p>

            <p class="text-gray-400">
              When I'm not coding, I'm usually listening to heavy music, playing
              guitar, or spending time with my wife and our dog.
            </p>

            <!-- Skill categories -->
            <div class="pt-2 space-y-5">
              {
                Object.entries(skills).map(([category, items]) => (
                  <div>
                    <h3 class="text-sm font-semibold text-gray-200">
                      {category}
                    </h3>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {items.map((item) => (
                        <span class="inline-flex items-center rounded-full bg-gray-800/50 border border-gray-700/60 px-3 py-1 text-sm text-gray-200">
                          {item}
                        </span>
                      ))}
                    </div>
                  </div>
                ))
              }
            </div>

            <!-- CTA link -->
            <div class="pt-2">
              <ArrowLink href="/blog" text="Read my articles" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
